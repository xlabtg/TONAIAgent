    "build:packages": "tsup --config tsup.config.packages.ts --clean",
    "build:sdk": "tsup --config tsup.config.ts --dts --clean",
    "dev": "tsup --config tsup.config.ts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
