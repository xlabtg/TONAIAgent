{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source for TONAIAgent metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" }
  ],
  "title": "TONAIAgent — Trading Performance",
  "description": "PnL, trade success rates, slippage, and drawdown monitoring (Issue #313)",
  "tags": ["TONAIAgent", "trading", "performance"],
  "timezone": "browser",
  "refresh": "1m",
  "schemaVersion": 38,
  "uid": "tonai-trading-performance",
  "panels": [
    {
      "id": 1,
      "title": "Total PnL (USD)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "tonaiagent_portfolio_pnl_usd", "legendFormat": "PnL" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "unit": "currencyUSD",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 0 }
          ]
        }
      }
    },
    {
      "id": 2,
      "title": "Trade Success Rate (24 h)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(tonaiagent_trades_success_total[24h]) / rate(tonaiagent_trades_total[24h])",
          "legendFormat": "Success Rate"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "unit": "percentunit",
        "colorMode": "background",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "red", "value": 0 },
            { "color": "yellow", "value": 0.40 },
            { "color": "green", "value": 0.60 }
          ]
        }
      }
    },
    {
      "id": 3,
      "title": "Average Slippage (bps)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "avg(tonaiagent_trade_slippage_bps)",
          "legendFormat": "Avg Slippage"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "unit": "short",
        "colorMode": "background",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 100 }
          ]
        }
      }
    },
    {
      "id": 4,
      "title": "Max Drawdown (1 h)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "min_over_time(tonaiagent_portfolio_drawdown_pct[1h])",
          "legendFormat": "Max Drawdown"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "unit": "percent",
        "colorMode": "background",
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": -10 },
            { "color": "yellow", "value": -20 },
            { "color": "red", "value": -100 }
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "Portfolio Value Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "tonaiagent_portfolio_value_usd",
          "legendFormat": "{{agent_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD" }
      }
    },
    {
      "id": 6,
      "title": "Trade Execution Time (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(tonaiagent_trade_execution_ms_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(tonaiagent_trade_execution_ms_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(tonaiagent_trade_execution_ms_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 7,
      "title": "Slippage Distribution (bps)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(tonaiagent_trade_slippage_bps_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(tonaiagent_trade_slippage_bps_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(tonaiagent_trade_slippage_bps_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "area" } }
        }
      }
    },
    {
      "id": 8,
      "title": "Trades Per Agent (24 h)",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "increase(tonaiagent_trades_total[24h])",
          "legendFormat": "{{agent_id}}",
          "instant": true
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "agent_id",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(tonaiagent_agent_status, agent_id)",
        "label": "Agent",
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {}
}
