# TON AI Agent - Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control!
# The .env file is listed in .gitignore for your protection.

# ============================================
# Application Settings
# ============================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ============================================
# Telegram Configuration
# ============================================
# Get your bot token from @BotFather: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# Your Mini App URL (after deployment)
TELEGRAM_MINI_APP_URL=

# Optional: Webhook secret for signature verification
TELEGRAM_WEBHOOK_SECRET=

# ============================================
# AI Providers
# ============================================
# Primary AI provider (Groq - fastest, free tier available)
# Get key from: https://console.groq.com
GROQ_API_KEY=

# Fallback AI providers (optional)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# ============================================
# TON Blockchain
# ============================================
# Network: mainnet or testnet
TON_NETWORK=testnet

# Custom RPC endpoint (optional — leave empty to use public endpoints)
TON_RPC_ENDPOINT=

# API key for toncenter (optional, for higher rate limits)
TONCENTER_API_KEY=

# ============================================
# TON Smart Contracts (Issue #308)
# ============================================
# REQUIRED: Owner address for the AgentFactory contract.
# Must NOT be the null address (0:0000…0000).
# For production, use a multi-sig wallet address.
FACTORY_OWNER_ADDRESS=

# REQUIRED: Treasury address that receives protocol fees.
# Must NOT be the null address.
# For production, use a multi-sig wallet address.
FACTORY_TREASURY_ADDRESS=

# REQUIRED: Address of the off-chain orchestrator authorised to submit
# AI signals to the StrategyExecutor contract.
STRATEGY_ORCHESTRATOR_ADDRESS=

# Deployed AgentFactory contract address (filled after deploy-testnet.ts)
AGENT_FACTORY_ADDRESS=

# Deployed StrategyExecutor contract address (filled after deploy-testnet.ts)
STRATEGY_EXECUTOR_ADDRESS=

# Deployer wallet mnemonic (24 words) — NEVER commit this to git!
# TON_MNEMONIC="word1 word2 ... word24"
TON_MNEMONIC=

# Toncenter API key for testnet RPC
TON_TESTNET_API_KEY=

# Toncenter API key for mainnet RPC (only needed for deploy-mainnet.ts)
TON_MAINNET_API_KEY=

# ============================================
# Security
# ============================================
# Encryption key for sensitive data (32+ chars)
# Generate with: openssl rand -hex 32
KEY_ENCRYPTION_KEY=

# JWT secret for API authentication
# Generate with: openssl rand -hex 32
JWT_SECRET=

# MPC configuration (for multi-party computation key management)
MPC_THRESHOLD=2
MPC_TOTAL_PARTIES=3

# ============================================
# Database (optional — required for production)
# ============================================
DATABASE_URL=

# ============================================
# Cache (optional — required for production)
# ============================================
REDIS_URL=

# ============================================
# Monitoring (optional)
# ============================================
# Sentry DSN for error tracking
SENTRY_DSN=

# ============================================
# MVP Feature Flags (Issue #247)
# ============================================
# Set ENABLE_EXTENDED=true to load post-MVP modules (extended/).
# Default is false — MVP runtime only.
# Non-MVP modules: hedgefund, tokenomics, dao-governance, institutional,
#   rwa, fund-manager, growth, launchpad, no-code, superapp, marketplace,
#   monetary-policy
ENABLE_EXTENDED=false
