{
  "name": "ton-ai-agent-contracts",
  "version": "1.0.0",
  "private": true,
  "description": "TON AI Agent smart contracts — Blueprint / Tact test suite",
  "scripts": {
    "test": "jest",
    "build": "npx blueprint build --all"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.spec.ts"],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    }
  },
  "devDependencies": {
    "@tact-lang/compiler": "^1.6.13",
    "@ton/blueprint": "^0.44.2",
    "@ton/core": "^0.63.1",
    "@ton/sandbox": "^0.41.0",
    "@ton/test-utils": "^0.12.0",
    "@types/jest": "^30.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.0.0"
  }
}
